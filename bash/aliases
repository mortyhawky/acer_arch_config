#!/usr/bin/env bash

####################################################
## GENERAL
####################################################
alias a="alias"
alias b="bat"
alias c=f_cdls
alias ff="clear && fastfetch"
alias g="grep -i --color=auto"
alias l="f_eza"
alias ll="f_eza --long"
alias mkcd=f_mkcd
alias sb="clear && source $HOME/.bashrc"
alias sc="sudo systemctl"
alias t="tmux"
alias v="nvim"
alias vf="vifm"
alias x="startx"

####################################################
## GIT
####################################################
alias gr="git remote -v"
alias gs="git status --verbose"
alias ga="git add --all --verbose && git status --short"
alias gc="git commit --message '$(date -Iseconds)'"
alias gp="git push --set-upstream origin main"
alias gitall="gr && gs && ga && gc && gp"

####################################################
## EDIT CONFIGS
####################################################
alias ev="nvim $XDG_CONFIG_HOME/nvim/init.lua"

#alias et="nvim $XDG_CONFIG_HOME/tmux/tumx.conf"

alias eb="nvim $XDG_CONFIG_HOME/bash/aliases    \
               $XDG_CONFIG_HOME/bash/functions  \
               $XDG_CONFIG_HOME/bash/exports    \
               $XDG_CONFIG_HOME/bash/debug      \
               $XDG_CONFIG_HOME/bash/completion \
               $XDG_CONFIG_HOME/bash/prompt     \
               $XDG_CONFIG_HOME/readline/inputrc     \
               $XDG_CONFIG_HOME/readline/options     \
               $XDG_CONFIG_HOME/readline/vi-mode     \
               $XDG_CONFIG_HOME/readline/keybind     \
               $XDG_CONFIG_HOME/readline/completions \
                && source $HOME/.bashrc"

alias ea="nvim $XDG_CONFIG_HOME/alacritty/alacritty.toml \
               $XDG_CONFIG_HOME/alacritty/keybidings"

alias ew="nvim $XDG_CONFIG_HOME/wezterm/wezterm.lua"

alias eg="sudo nvim /etc/default/grub && sudo grub-mkconfig -o /boot/grub/grub.cfg"

####################################################
## ADMIN
####################################################
alias dm="sudo dmesg"
alias fdisk="sudo fdisk --list"
alias lb="lsblk -o NAME,SIZE,FSTYPE,UUID,MOUNTPOINT"
alias upd=f_update
alias poweroff="sudo poweroff"
alias reboot="sudo reboot"
