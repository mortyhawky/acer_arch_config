#!/usr/bin/env bash

alias b="bat"
alias c="f_cdls"
alias ew="nvim $XDG_CONFIG_HOME/wezterm/wezterm.lua"
alias ea="nvim $XDG_CONFIG_HOME/bash/aliases && source $HOME/.bashrc"
