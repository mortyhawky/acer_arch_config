ctrl + super + F8
    env > ~/sxhkd-env

#super + Return
#  $TERMINAL
#
#super + w
#  $BROWSER

super + r
  rofi -show drun

## Reload sxhkd
ctrl + super + r
  pkill -USR1 -x sxhkd

## Reload bspwm
super + alt + r
  bspc wm -r

## ###############################################
##   BSPWM   HOTKEYS
## ###############################################

## focus the node in the given direction
super + {h,j,k,l}
	bspc node --focus {west,south,north,east}

# Resize window (Super + Shift + hl)
# Resize focused window - Horizontal (h = narrower, l = wider)
super + shift + h
    bspc node --resize left -20 0 || bspc node -z right -20 0

super + shift + l
    bspc node -z right 20 0 || bspc node -z left 20 0

# Resize window (Super + Shift + jk)
# Resize focused window - Vertical (j = shorter, k = taller)
super + shift + j
    bspc node -z bottom 0 20 || bspc node -z top 0 20

super + shift + k
    bspc node -z top 0 -20 || bspc node -z bottom 0 -20

## Close focused window
super + q
  bspc node --close

## quit bspwm
super + shift + q
  bspc quit

## alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

## Promote window
super + shift + Return
  bspc node --swap biggest.local

# focus or send to the given desktop
# Super + 1-9,0 go to desktop 
# Super + 1-9,0 send node to given desktop
super + {_, shift + }{1-9,0}
	bspc {desktop --focus, node --to-desktop} '^{1-9,10}'

